---
import { cmsURL } from "@/constants";
import extractPlainTextFromRichText from "@utils/extractPlainTextFromRichText";
import resolveOgImage from "@/utils/resolveOgImage";
import { personRef } from "@/utils/personSchema";
import Layout from "@/layouts/layout.astro";
import JsonLd from "@/components/seo/jsonLd.astro";
import CaseStudyIntroduction from "./sections/caseStudyIntroduction.astro";
import CaseStudyContent from "./sections/caseStudyContent.astro";
import CaseStudyOtherProjects from "./sections/caseStudyOtherProjects.astro";
import CaseStudyContactLinks from "./sections/caseStudyContactLinks.astro";

export interface CaseStudyType {
  title: string;
  id: string;
  slug: string;
  // /api/case-studies/all does not include width/height, unlike other
  // endpoints that return the full media doc — inferSize is required here.
  // Null when the case study has no thumbnail set.
  thumbnailImage: { url: string; alt: string } | null;
}

const { slug } = Astro.params;

const [caseStudiesResponse, pageResponse] = await Promise.all([
  fetch(`${cmsURL}/api/case-studies/all`, { credentials: "include" }),
  fetch(`${cmsURL}/api/case-studies/by-slug/${slug}`),
]);

const [caseStudies, page]: [CaseStudyType[], any] = await Promise.all([
  caseStudiesResponse.json(),
  pageResponse.json(),
]);

const currentCaseStudy = caseStudies.find((_) => _.slug === slug);

if (!currentCaseStudy) {
  return Astro.redirect("/404");
}

const otherCaseStudies = caseStudies.filter(
  (caseStudy) => caseStudy.slug !== slug,
);

// The browser should always check freshness
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, must-revalidate",
);

// The CDN caches for a year, invalidated by tag when content changes
Astro.cache.set({
  maxAge: 31536000,
  tags: ["global", "case-studies", currentCaseStudy.id],
});

const plainDescription =
  page.meta?.description ||
  extractPlainTextFromRichText(page.thumbnail.description).slice(0, 155);

const ogImage =
  resolveOgImage(page.meta?.image) || resolveOgImage(page.thumbnail.thumbnailImage);

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const structuredData = [
  {
    "@type": "CreativeWork",
    headline: page.title,
    description: plainDescription,
    url: canonicalURL,
    image: ogImage?.url,
    dateModified: page.updatedAt,
    author: personRef,
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://thong.cam/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: page.title,
        item: canonicalURL,
      },
    ],
  },
];
---

<Layout
  pageMetaDescription={plainDescription}
  pageTitle={page.title}
  pageOgMeta={{
    title: page.meta?.title || page.title,
    description: plainDescription,
    image: ogImage,
  }}
  themeColor={page.themeColor}
>
  <JsonLd graph={structuredData} slot="head" />
  <CaseStudyIntroduction page={page} />
  <CaseStudyContent page={page} />
  <CaseStudyOtherProjects otherCaseStudies={otherCaseStudies} />
  <CaseStudyContactLinks />
</Layout>
