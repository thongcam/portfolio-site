---
interface Props {
  graph: object[];
}

const { graph } = Astro.props as Props;

const data =
  graph.length === 1
    ? { "@context": "https://schema.org", ...graph[0] }
    : { "@context": "https://schema.org", "@graph": graph };

// Escape "<" so a stray "</script>" in CMS-sourced text can't break out of the tag.
const json = JSON.stringify(data).replace(/</g, "\\u003c");
---

<script type="application/ld+json" is:inline set:html={json} />
