---
import "@fontsource-variable/nunito";
import Nunito from "@fontsource-variable/nunito/files/nunito-latin-wght-normal.woff2";
import "@fontsource-variable/noto-serif";
import NotoSerif from "@fontsource-variable/noto-serif/files/noto-serif-latin-wght-normal.woff2";
import Footer from "@/components/footer/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import { cmsURL } from "@/constants";
import getGlobals from "@/utils/getGlobals";
import resolveOgImage, { type OgImage } from "@/utils/resolveOgImage";
import "../styles/global.css";

interface Props {
  pageMetaDescription?: string;
  pageTitle?: string;
  pageOgMeta?: {
    title?: string;
    description?: string;
    image?: OgImage;
  };
  themeColor?: string;
}

const { logos, settings } = await getGlobals(Astro.locals);
const { pageMetaDescription, pageTitle, pageOgMeta, themeColor } =
  Astro.props as Props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const fallbackOgImage = resolveOgImage(settings.ogMetadata?.image);

const resolvedTitle = pageTitle
  ? `${pageTitle} | ${settings.siteTitle}`
  : settings.siteTitle;
const ogTitle = pageOgMeta?.title || resolvedTitle;
const ogDescription =
  pageOgMeta?.description || pageMetaDescription || settings.siteDescription;
const ogImage = pageOgMeta?.image || fallbackOgImage;
---

<html lang="en" class="scroll-smooth scroll-p-15 md:scroll-m-0">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/images/logo-small.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preload" as="font" type="font/woff2" href={Nunito} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={NotoSerif} crossorigin="anonymous" />
    <link rel="preconnect" href="https://admin.thong.cam" crossorigin>
    <link rel="preconnect" href="https://umami.thong.cam">
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageMetaDescription || settings.siteDescription} />

    <meta property="og:locale" content={settings.ogMetadata.locale} />
    <meta property="og:type" content={settings.ogMetadata.type} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={settings.siteTitle} />
    <meta property="og:logo" content={cmsURL + logos.logoSmall.url} />
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage.url} />
          <meta property="og:image:secure_url" content={ogImage.url} />
          {ogImage.width && (
            <meta property="og:image:width" content={String(ogImage.width)} />
          )}
          {ogImage.height && (
            <meta property="og:image:height" content={String(ogImage.height)} />
          )}
          <meta property="og:image:alt" content={ogImage.alt || ogTitle} />
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage.url} />}

    <title>{resolvedTitle}</title>
    <script defer src="https://umami.thong.cam/script.js" data-website-id="b924d487-517b-4512-a0e0-4ba9d69b1c36"></script>
    <slot name="head" />
  </head>
  <body class="text-dark-blue font-body" style={themeColor ? `--theme-color: ${themeColor}` : null}>
    <Navbar logos={logos} themeColor={themeColor} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
